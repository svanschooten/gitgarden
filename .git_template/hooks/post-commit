#!/bin/sh

set -e

SCRIPT_NAME="garden.js"
SKIP_FLAG="[skip garden]"

if [ "$SKIP_GARDEN" = "1" ]; then
  exit 0
fi

COMMIT_MSG=$(git log -1 --pretty=%B)
if echo "$COMMIT_MSG" | grep -qiF "$SKIP_FLAG"; then
  exit 0
fi

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
[ -z "$REPO_ROOT" ] && exit 0

if [ -z "$GITGARDEN_REPO_PATH" ]; then
  echo "GITGARDEN_REPO_PATH not set, skipping" > /dev/tty
  exit 0
fi
SCRIPT_PATH="$GITGARDEN_REPO_PATH/$SCRIPT_NAME"

if [ ! -f "$SCRIPT_PATH" ]; then
  echo "$SCRIPT_NAME not found, skipping" > /dev/tty
  exit 0
else
  echo "🌱  Git Garden Growing!" > /dev/tty
fi

REPO_NAME=$(basename "$REPO_ROOT")
cmd="node \"$SCRIPT_PATH\" --repo \"$REPO_NAME\""

for f in $(git diff-tree --no-commit-id --name-only -r HEAD); do
  diff=$(git show HEAD:"$f" 2>/dev/null | sed "s/'/'\\\\''/g")
  cmd="$cmd --file '$f' --diff '$diff'"
done

if [ -n "$GITGARDEN_TARGET" ]; then
  cmd="$cmd --target \"$GITGARDEN_TARGET\""
fi

eval "$cmd" > /dev/tty

exit 0